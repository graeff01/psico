# Database
DATABASE_URL=postgresql://user:password@localhost:5432/psicoia

# Server
PORT=3000
NODE_ENV=development

# Encryption
ENCRYPTION_KEY=your-32-byte-hex-key-here-64-chars
ENCRYPTION_SALT=your-random-salt-here

# Better Auth
BETTER_AUTH_SECRET=your-auth-secret-here
BETTER_AUTH_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-key-here

# S3 Storage (Railway Buckets or AWS S3)
S3_ENDPOINT=https://your-bucket.railway.app
S3_REGION=us-east-1
S3_BUCKET=psicoia-storage
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Email (Resend)
RESEND_API_KEY=re_your-resend-key-here
EMAIL_FROM=noreply@psicoia.com.br
