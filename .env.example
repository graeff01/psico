# ═══════════════════════════════════════════
# PsicoIA Manager - Variáveis de Ambiente
# ═══════════════════════════════════════════

# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/psicoia

# Server
PORT=3000
NODE_ENV=development

# Encryption (gere com: openssl rand -hex 32)
ENCRYPTION_KEY=gere_uma_chave_hex_64_caracteres_com_openssl_rand_hex_32
ENCRYPTION_SALT=gere_um_salt_aleatorio_aqui

# Better Auth
BETTER_AUTH_SECRET=gere_um_secret_de_pelo_menos_32_caracteres
BETTER_AUTH_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-sua-chave-openai-aqui

# S3 Storage (Railway Buckets)
S3_ENDPOINT=https://seu-bucket.railway.app
S3_REGION=us-east-1
S3_BUCKET=psicoia-storage
S3_ACCESS_KEY=sua-access-key
S3_SECRET_KEY=sua-secret-key

# Email (Resend - opcional)
RESEND_API_KEY=re_sua-chave-resend
EMAIL_FROM=noreply@psicoia.com.br
